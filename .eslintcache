errorCount":0,"warningCount":11,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"70","messages":"71","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/leecho/study/triper-react/src/service/Service.tsx",[],["72","73"],"/Users/leecho/study/triper-react/src/service/ServiceList.ts",[],"/Users/leecho/study/triper-react/src/pages/member/index.tsx",[],"/Users/leecho/study/triper-react/src/components/common/Intro.tsx",["74"],"/** @jsxImportSource @emotion/react */\nimport { css } from \"@emotion/react\";\nimport { IntroStyle } from './Intro.style';\n\nconst Intro:React.FC = () => {\n    return (\n        <section css={IntroStyle}>\n            <h1>TRIPER</h1>\n            <p>\n                copyright LEECHO<br />\n                ALL RIGHT RESERVED\n            </p>\n            <img src=\"/images/intro.jpg\" alt=\"\"/>\n        </section>\n    )\n}\n\nexport default Intro;",["75","76"],"/Users/leecho/study/triper-react/src/App.tsx",[],"/Users/leecho/study/triper-react/src/components/home/CitiesList.tsx",["77"],"import styled from 'styled-components';\nimport classNames from 'classnames';\n\ninterface ICitiesItem {\n    code: Number;\n    name: String;\n    rnum: Number;\n}\n\ninterface IProps {\n    data?: ICitiesItem[]\n}\n\nconst CitiesListWrapper = styled.section`\n    position:relative;\n    display:flex;\n    flex-wrap:no-wrap;\n    overflow-x:auto;\n    overflow-y:hidden;\n    padding:15px;\n    &:after {\n        content:'';\n        padding-left:12px;\n    }\n\n    button {\n        position:relative;\n        overflow:hidden;\n        flex:0 0 auto;\n        margin-left:12px;\n        border-radius:4px;\n\n        &:first-of-type {\n            margin-left:0;\n        }\n\n        &.active {            \n            img {\n                opacity:1;\n            }\n        }\n\n        img {\n            width:120px;\n            opacity:.7;\n        }\n\n        .text {\n            position:absolute;\n            left:10px;\n            bottom:10px;\n            font-weight:bold;\n            font-size:14px;\n            color:#fff;\n        }\n    }\n`\n\nconst CitiesList: React.FC<IProps> = ({\n    data\n}) => {\n    return (\n        <CitiesListWrapper>\n            { data && data.length > 0 && data.map((item: ICitiesItem, index: number) => (\n                <button type=\"button\" key={`citeis_${index}`} className={index === 0 ? 'active' : undefined}>\n                    <img src={`/images/cities/city_${item.code}.jpg`} alt={`${item.name === '세종특별자치시' ? '세종시' : item.name}`} />\n                    <span className=\"text\">{item.name === '세종특별자치시' ? '세종시' : item.name}</span>\n                </button>\n            )) }\n        </CitiesListWrapper>\n    )\n}\n\nexport default CitiesList;","/Users/leecho/study/triper-react/src/index.tsx",[],"/Users/leecho/study/triper-react/src/assets/style/media.js",[],["78","79"],"/Users/leecho/study/triper-react/src/assets/style/theme.js",["80"],"import styled from 'styled-components';\n\nconst colors = {\n    mainTxtColor: '#333',\n    subTxtColor: '#999',\n    borderColor: '#f7f7f7'\n}\n\nconst theme = {\n    colors\n}\n\nexport default theme;","/Users/leecho/study/triper-react/src/router/index.tsx",[],"/Users/leecho/study/triper-react/src/layout/Container.tsx",[],"/Users/leecho/study/triper-react/src/router/routes.tsx",[],"/Users/leecho/study/triper-react/src/layout/NavBar.tsx",[],"/Users/leecho/study/triper-react/src/router/pages.tsx",["81"],"/Users/leecho/study/triper-react/src/pages/home/index.tsx",["82","83","84","85","86","87","88","89","90","91","92"],"/Users/leecho/study/triper-react/src/pages/search/index.tsx",[],{"ruleId":"93","replacedBy":"94"},{"ruleId":"95","replacedBy":"96"},{"ruleId":"97","severity":1,"message":"98","line":2,"column":10,"nodeType":"99","messageId":"100","endLine":2,"endColumn":13},{"ruleId":"93","replacedBy":"101"},{"ruleId":"95","replacedBy":"102"},{"ruleId":"97","severity":1,"message"