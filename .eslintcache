n            img {\n                opacity:1;\n            }\n        }\n\n        img {\n            width:120px;\n            opacity:.7;\n        }\n\n        .text {\n            position:absolute;\n            left:10px;\n            bottom:10px;\n            font-weight:bold;\n            font-size:14px;\n            color:#fff;\n        }\n    }\n`\n\nconst CitiesList: React.FC<IProps> = ({\n    data\n}) => {\n    return (\n        <CitiesListWrapper>\n            { data && data.length > 0 && data.map((item: ICitiesItem, index: number) => (\n                <button type=\"button\" key={`citeis_${index}`} className={index === 0 ? 'active' : undefined}>\n                    <img src={`/images/cities/city_${item.code}.jpg`} alt={`${item.name === '세종특별자치시' ? '세종시' : item.name}`} />\n                    <span className=\"text\">{item.name === '세종특별자치시' ? '세종시' : item.name}</span>\n                </button>\n            )) }\n        </CitiesListWrapper>\n    )\n}\n\nexport default CitiesList;","/Users/leecho/study/triper-react/src/index.tsx",[],"/Users/leecho/study/triper-react/src/assets/style/media.js",[],["83","84"],"/Users/leecho/study/triper-react/src/assets/style/theme.js",["85"],"import styled from 'styled-components';\n\nconst colors = {\n    mainTxtColor: '#333',\n    subTxtColor: '#999',\n    borderColor: '#f7f7f7'\n}\n\nconst theme = {\n    colors\n}\n\nexport default theme;","/Users/leecho/study/triper-react/src/router/index.tsx",[],"/Users/leecho/study/triper-react/src/layout/Container.tsx",[],"/Users/leecho/study/triper-react/src/router/routes.tsx",[],"/Users/leecho/study/triper-react/src/layout/NavBar.tsx",[],"/Users/leecho/study/triper-react/src/router/pages.tsx",["86"],"import Home from '@pages/home';\nimport Member from '@pages/member';\nimport Search from '@pages/search';\n\nexport default {\n    Home,\n    Member,\n    Search\n}","/Users/leecho/study/triper-react/src/pages/home/index.tsx",["87","88","89","90","91","92","93","94","95","96","97"